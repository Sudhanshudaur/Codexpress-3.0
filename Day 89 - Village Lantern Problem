#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<int> arr(n);
        for (int i = 0; i < n; i++) {
            cin >> arr[i];
        }

        unordered_map<int, vector<long long>> positions;

        for (int i = 0; i < n; i++) {
            positions[arr[i]].push_back(i);
        }

        vector<long long> result(n, 0);

        for (auto &entry : positions) {
            vector<long long> &pos = entry.second;
            int k = pos.size();

            if (k == 1) continue;

            vector<long long> prefix(k, 0);
            prefix[0] = pos[0];
            for (int i = 1; i < k; i++) {
                prefix[i] = prefix[i - 1] + pos[i];
            }

            for (int i = 0; i < k; i++) {
                long long left = 0;
                long long right = 0;

                if (i > 0) {
                    left = (long long)i * pos[i] - prefix[i - 1];
                }

                if (i < k - 1) {
                    right = (prefix[k - 1] - prefix[i]) - 
                            (long long)(k - i - 1) * pos[i];
                }

                result[pos[i]] = left + right;
            }
        }

        for (int i = 0; i < n; i++) {
            cout << result[i] << " ";
        }
        cout << "\n";
    }

    return 0;
}
