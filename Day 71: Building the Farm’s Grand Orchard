#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* left;
    Node* right;
    
    Node(int val) {
        data = val;
        left = right = NULL;
    }
};

Node* insert(Node* root, int val) {
    if (root == NULL)
        return new Node(val);

    if (val <= root->data)  // duplicates go to LEFT
        root->left = insert(root->left, val);
    else
        root->right = insert(root->right, val);

    return root;
}

int height(Node* root) {
    if (root == NULL)
        return 0;

    return 1 + max(height(root->left), height(root->right));
}

int main() {
    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        Node* root = NULL;

        for (int i = 0; i < n; i++) {
            int x;
            cin >> x;
            root = insert(root, x);
        }

        cout << height(root) << endl;
    }

    return 0;
}
