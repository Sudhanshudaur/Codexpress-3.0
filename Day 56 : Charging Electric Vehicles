#include <bits/stdc++.h>

using namespace std;

int main() {

    ios::sync_with_stdio(false);

    cin.tie(nullptr);

    int T;

    cin >> T;

    while (T--) {

        int a, b, c;

        cin >> a >> b >> c;

        int sum = a + b + c;

        int mx = max({a, b, c});

        // Ceil(sum / 2)

        int half = (sum + 1) / 2;

        int result = max(mx, half);

        cout << result << "\n";

    }

    return 0;

}
