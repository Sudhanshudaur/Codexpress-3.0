#include <bits/stdc++.h>
using namespace std;

int minHeightDiff(vector<int>& nums, int k) {
    int n = nums.size();
    if (n == 1) return 0;
    
    sort(nums.begin(), nums.end());
    
    // Initial difference without any adjustment
    int result = nums[n-1] - nums[0];
    
    for (int i = 0; i < n - 1; i++) {
        // Hills 0..i go up (+k), hills i+1..n-1 go down (-k)
        int maxVal = max(nums[i] + k, nums[n-1] - k);
        int minVal = min(nums[0] + k, nums[i+1] - k);
        result = min(result, max(0, maxVal - minVal));
    }
    
    return result;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    
    while (t--) {
        int n, k;
        cin >> n >> k;
        
        vector<int> nums(n);
        for (int i = 0; i < n; i++) cin >> nums[i];
        
        cout << minHeightDiff(nums, k) << "\n";
    }
    
    return 0;
}
