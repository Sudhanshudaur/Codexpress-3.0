#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n, k;
        cin >> n >> k;

        vector<int> tickets(n);
        for (int i = 0; i < n; i++) {
            cin >> tickets[i];
        }

        int time = 0;
        int target = tickets[k];

        for (int i = 0; i < n; i++) {
            if (i <= k) {
                time += min(tickets[i], target);
            } else {
                time += min(tickets[i], target - 1);
            }
        }

        cout << time << "\n";
    }

    return 0;
}
