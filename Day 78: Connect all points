#include <bits/stdc++.h>
using namespace std;

long long manhattanDistance(pair<int,int> a, pair<int,int> b) {
    return abs(a.first - b.first) + abs(a.second - b.second);
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int T;
    cin >> T;

    while(T--) {
        int n;
        cin >> n;

        vector<pair<int,int>> points(n);
        for(int i = 0; i < n; i++) {
            cin >> points[i].first >> points[i].second;
        }

        // Prim's Algorithm
        vector<long long> minDist(n, LLONG_MAX);
        vector<bool> visited(n, false);

        minDist[0] = 0;  // start from point 0
        long long totalCost = 0;

        for(int i = 0; i < n; i++) {
            int u = -1;

            // Pick minimum distance unvisited node
            for(int j = 0; j < n; j++) {
                if(!visited[j] && (u == -1 || minDist[j] < minDist[u])) {
                    u = j;
                }
            }

            visited[u] = true;
            totalCost += minDist[u];

            // Update distances
            for(int v = 0; v < n; v++) {
                if(!visited[v]) {
                    long long dist = manhattanDistance(points[u], points[v]);
                    if(dist < minDist[v]) {
                        minDist[v] = dist;
                    }
                }
            }
        }

        cout << totalCost << "\n";
    }

    return 0;
}
