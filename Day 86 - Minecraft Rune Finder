#include <bits/stdc++.h>
using namespace std;

int m, n;
vector<vector<char>> grid;
string word;

bool dfs(int r, int c, int index) {
    if (index == word.length()) 
        return true;

    if (r < 0 || c < 0 || r >= m || c >= n || grid[r][c] != word[index])
        return false;

    char temp = grid[r][c];
    grid[r][c] = '#';  // mark visited

    bool found = dfs(r+1, c, index+1) ||
                 dfs(r-1, c, index+1) ||
                 dfs(r, c+1, index+1) ||
                 dfs(r, c-1, index+1);

    grid[r][c] = temp;  // backtrack
    return found;
}

int main() {
    cin >> m >> n;
    grid.resize(m, vector<char>(n));

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            cin >> grid[i][j];
        }
    }

    cin >> word;

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            if (dfs(i, j, 0)) {
                cout << "true";
                return 0;
            }
        }
    }

    cout << "false";
    return 0;
}
