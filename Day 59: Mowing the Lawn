#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        unordered_set<int> s;

        for (int i = 0; i < n; i++) {
            int x;
            cin >> x;

            if (x > 0) {
                s.insert(x);
            }
        }

        // Number of distinct positive heights
        cout << s.size() << "\n";
    }

    return 0;
}
