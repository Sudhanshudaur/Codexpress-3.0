#include <bits/stdc++.h>
using namespace std;

int minJumps(vector<int>& nums, int n) {
    if (n <= 1) return 0;
    if (nums[0] == 0) return -1;

    int maxReach = nums[0];
    int steps = nums[0];
    int jumps = 1;

    for (int i = 1; i < n; i++) {
        if (i == n - 1)
            return jumps;

        maxReach = max(maxReach, i + nums[i]);
        steps--;

        if (steps == 0) {
            jumps++;

            if (i >= maxReach)
                return -1;

            steps = maxReach - i;
        }
    }

    return -1;
}

int main() {
    int T;
    cin >> T;

    while (T--) {
        int N;
        cin >> N;

        vector<int> nums(N);
        for (int i = 0; i < N; i++)
            cin >> nums[i];

        cout << minJumps(nums, N) << endl;
    }
}
