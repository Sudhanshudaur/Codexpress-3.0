#include <iostream>
#include <vector>
using namespace std;

int main() {
    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<int> villagers(n), meals(n);

        int count0 = 0, count1 = 0;

        for (int i = 0; i < n; i++) {
            cin >> villagers[i];
            if (villagers[i] == 0)
                count0++;
            else
                count1++;
        }

        for (int i = 0; i < n; i++) {
            cin >> meals[i];
        }

        for (int i = 0; i < n; i++) {
            if (meals[i] == 0) {
                if (count0 > 0)
                    count0--;
                else
                    break;
            } else {
                if (count1 > 0)
                    count1--;
                else
                    break;
            }
        }

        cout << count0 + count1 << endl;
    }

    return 0;
}
