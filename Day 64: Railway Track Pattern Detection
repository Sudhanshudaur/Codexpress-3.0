#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<long long> heights(n);
        for (int i = 0; i < n; i++) {
            cin >> heights[i];
        }

        stack<long long> st;
        long long third = LLONG_MIN; // represents heights[k]

        bool found = false;

        // Traverse from right to left
        for (int i = n - 1; i >= 0; i--) {

            // Check if heights[i] < heights[k]
            if (heights[i] < third) {
                found = true;
                break;
            }

            // Update third while popping smaller elements
            while (!st.empty() && st.top() < heights[i]) {
                third = st.top();
                st.pop();
            }

            // Push current element
            st.push(heights[i]);
        }

        if (found)
            cout << "Yes\n";
        else
            cout << "No\n";
    }

    return 0;
}
