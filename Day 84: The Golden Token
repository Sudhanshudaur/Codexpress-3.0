#include <bits/stdc++.h>
using namespace std;

int maximumSwap(int num) {
    string s = to_string(num);
    int n = s.size();
    
    // Store last occurrence of each digit
    vector<int> last(10, -1);
    for (int i = 0; i < n; i++) {
        last[s[i] - '0'] = i;
    }
    
    // Try to find best swap
    for (int i = 0; i < n; i++) {
        for (int d = 9; d > s[i] - '0'; d--) {
            if (last[d] > i) {
                swap(s[i], s[last[d]]);
                return stoi(s);
            }
        }
    }
    
    return num; // already maximum
}

int main() {
    int T;
    cin >> T;
    
    while (T--) {
        int tokenNumber;
        cin >> tokenNumber;
        cout << maximumSwap(tokenNumber) << endl;
    }
    
    return 0;
}
