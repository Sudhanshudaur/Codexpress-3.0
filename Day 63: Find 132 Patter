#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<long long> nums(n);
        for (int i = 0; i < n; i++) {
            cin >> nums[i];
        }

        stack<long long> st;
        long long third = LLONG_MIN; // represents nums[k]

        bool found = false;

        // Traverse from right to left
        for (int i = n - 1; i >= 0; i--) {

            // If we find nums[i] < nums[k]
            if (nums[i] < third) {
                found = true;
                break;
            }

            // Update "third" while stack top is smaller
            while (!st.empty() && st.top() < nums[i]) {
                third = st.top();
                st.pop();
            }

            // Push current as potential "3"
            st.push(nums[i]);
        }

        if (found)
            cout << "Yes\n";
        else
            cout << "No\n";
    }

    return 0;
}
