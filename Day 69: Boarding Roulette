#include <iostream>
#include <vector>
using namespace std;

int main() {
    int T;
    cin >> T;
    
    while (T--) {
        int n;
        cin >> n;
        
        vector<int> passengers(n), seats(n);
        
        int count0 = 0, count1 = 0;
        
        // Read passengers
        for (int i = 0; i < n; i++) {
            cin >> passengers[i];
            if (passengers[i] == 0)
                count0++;
            else
                count1++;
        }
        
        // Read seats
        for (int i = 0; i < n; i++) {
            cin >> seats[i];
        }
        
        int remaining = n;
        
        for (int i = 0; i < n; i++) {
            if (seats[i] == 0) {
                if (count0 > 0) {
                    count0--;
                    remaining--;
                } else {
                    break;
                }
            } else {
                if (count1 > 0) {
                    count1--;
                    remaining--;
                } else {
                    break;
                }
            }
        }
        
        cout << remaining << endl;
    }
    
    return 0;
}
