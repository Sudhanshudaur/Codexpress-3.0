#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<int> nums(n);
        for (int i = 0; i < n; i++)
            cin >> nums[i];

        sort(nums.begin(), nums.end());

        int count = 0;
        int prev = -1;

        for (int x : nums) {
            if (x > 0 && x != prev) {
                count++;
                prev = x;
            }
        }

        cout << count << "\n";
    }

    return 0;
}
