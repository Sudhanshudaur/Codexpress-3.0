#include <iostream>
using namespace std;

int josephus(int n, int k) {
    int result = 0;  // f(1, k) = 0
    
    for (int i = 2; i <= n; i++) {
        result = (result + k) % i;
    }
    
    return result + 1;  // Convert 0-based index to 1-based
}

int main() {
    int T;
    cin >> T;
    
    while (T--) {
        int n, k;
        cin >> n >> k;
        
        cout << josephus(n, k) << endl;
    }
    
    return 0;
}
